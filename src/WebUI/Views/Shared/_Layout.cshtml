<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — License Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/gov.css" rel="stylesheet" />
</head>
<body>

@{
    var username    = Context.Session.GetString("username");
    var role        = Context.Session.GetString("role");
    var isLoggedIn  = !string.IsNullOrEmpty(username);
    var isAdmin     = role == "Admin";
}

@if (isLoggedIn)
{
    <!-- ── Top Navigation Bar ──────────────────────────────────────── -->
    <nav class="navbar navbar-dark gov-navbar fixed-top px-3">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-link text-white p-0 sidebar-toggle" id="sidebarToggle">
                <i class="bi bi-list fs-4"></i>
            </button>
            <a class="navbar-brand d-flex align-items-center gap-2 mb-0" href="#">
                <i class="bi bi-shield-check fs-5"></i>
                <span class="fw-bold">License Management System</span>
            </a>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="badge @(isAdmin ? "bg-danger" : "bg-info text-dark") px-3 py-2">
                <i class="bi @(isAdmin ? "bi-shield-fill" : "bi-person-fill") me-1"></i>@role
            </span>
            <span class="text-white-50 small">@username</span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            </form>
        </div>
    </nav>

    <!-- ── Sidebar ──────────────────────────────────────────────────── -->
    <nav id="sidebar" class="gov-sidebar">
        <div class="sidebar-header">
            <i class="bi bi-building fs-4"></i>
            <span class="ms-2 fw-semibold">Gov Portal</span>
        </div>
        <ul class="nav flex-column mt-2">
            @if (isAdmin)
            {
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "AdminDashboard" ? "active" : "")"
                       asp-controller="Dashboard" asp-action="AdminDashboard">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "AllApplications" ? "active" : "")"
                       asp-controller="Dashboard" asp-action="AdminDashboard" asp-route-status="">
                        <i class="bi bi-card-list me-2"></i>All Applications
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Pending" ? "active" : "")"
                       asp-controller="Dashboard" asp-action="AdminDashboard" asp-route-status="Pending">
                        <i class="bi bi-clock-history me-2"></i>Pending Review
                    </a>
                </li>
            }
            else
            {
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "UserDashboard" ? "active" : "")"
                       asp-controller="Dashboard" asp-action="UserDashboard">
                        <i class="bi bi-house-door me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Apply" ? "active" : "")"
                       asp-controller="Dashboard" asp-action="Apply">
                        <i class="bi bi-plus-circle me-2"></i>Apply for License
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "MyLicenses" ? "active" : "")"
                       asp-controller="Dashboard" asp-action="UserDashboard">
                        <i class="bi bi-file-earmark-text me-2"></i>My Licenses
                    </a>
                </li>
            }
        </ul>
        <div class="sidebar-footer">
            <small class="text-muted">v1.0 · Gov Tech Division</small>
        </div>
    </nav>

    <!-- ── Main Content ─────────────────────────────────────────────── -->
    <main class="gov-main" id="mainContent">
        <!-- Alert Banner -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mx-3 mt-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mx-3 mt-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>
}
else
{
    <!-- Public layout (no sidebar) -->
    <div class="gov-public-bg min-vh-100">
        @RenderBody()
    </div>
}

<!-- ── Footer ──────────────────────────────────────────────────────────── -->
@if (isLoggedIn)
{
    <footer class="gov-footer">
        <span>Government Technology Division &nbsp;|&nbsp; License Management System &nbsp;|&nbsp; v1.0</span>
        <span class="text-danger fw-semibold ms-3">INTERNAL USE ONLY</span>
    </footer>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/gov.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
